      "parameters": {
        "deviationRatio": 0.3
      }
    },

    "R9": {
      "enabled": false,
      "level": "预警",
      "displayName": "转换段瞬态阻力",
      "type": "morphology",
      "provenance": "domain-expert",
      "provenanceNote": "滑动窗口局部均值扫描——检测转换段内瞬时功率脉冲。这是隐性问题的核心检测规则：转辙机凭借余量克服了阻力点，整段均值正常但局部存在异常脉冲。",
      "parameters": {
        "windowSize": 20,
        "transientThreshold": 1.5,
        "windowSizeNote": "20点=0.8s，对应一次短暂阻力事件的典型持续时间",
        "transientThresholdNote": "1.5×refConvMean，约5σ偏离正常波动范围"
      },
      "status": "pending_implementation"
    },

    "R10": {
      "enabled": false,
      "level": "预警",
      "displayName": "转换段稳定性异常",
      "type": "morphology",
      "provenance": "domain-expert",
      "provenanceNote": "去趋势残差标准差检测液压系统压力稳定性。粗糙度增大说明油压波动，可能原因：气泡、密封老化、油泵叶片磨损。",
      "parameters": {
        "roughnessRatioThreshold": 2.0,
        "movingMedianWindow": 11,
        "roughnessRatioNote": ">refRoughness×2.0触发预警。实际阈值需在dryrun后根据正常roughness分布标定。"
      },
      "status": "pending_implementation"
    },

    "R11": {
      "enabled": false,
      "level": "预警",
      "displayName": "解锁/转换比例失调",
      "type": "threshold",
      "provenance": "domain-expert",
      "provenanceNote": "段间比例关系比单段绝对值更早反映问题。unlockMean/convMean偏离参考>0.2时触发。比例偏大→密贴过紧；偏小→滑床板缺油。",
      "parameters": {
        "ratioDeviationThreshold": 0.2,
        "ratioDeviationNote": "以1-1为例 refRatio=0.307/0.300=1.023。偏离±0.2即<0.823或>1.223时预警。"
      },
      "status": "pending_implementation"
    },

    "R12": {
      "enabled": false,
      "level": "预警",
      "displayName": "尖峰半高宽异常",
      "type": "morphology",
      "provenance": "domain-expert",
      "provenanceNote": "启动尖峰半高宽反映油泵建压速度。偏离参考±40%提示油泵启动特性变化（电机老化/液压油粘度变化）。",
      "parameters": {
        "halfWidthDeviationRatio": 0.4
      },
      "status": "pending_implementation"
    },

    "R13": {
      "enabled": false,
      "level": "预警",
      "displayName": "尖峰回落不足",
      "type": "morphology",
      "provenance": "domain-expert",
      "provenanceNote": "尖峰后功率回落幅度不足(SpikeDropRatio<0.7)说明溢流阀响应迟缓或液压管路存在异常节流。",
      "parameters": {
        "spikeDropRatioMin": 0.7
      },
      "status": "pending_implementation"
    },

    "T1": {
      "enabled": false,
      "level": "预警",
      "displayName": "渐变劣化趋势",
      "type": "trend",
      "provenance": "domain-expert",
      "provenanceNote": "7天滑动中位数单调不减+超基线×(1+trendRatio)时预警。滑床板缺油以周为单位发展，单次动作永不超过1.3×阈值，只有趋势能发现。",
      "parameters": {
        "trendRatio": 0.15,
        "trendDays": 7,
        "features": ["convMean", "durationSec"]
      },
      "status": "pending_implementation"
    },

    "P1": {
      "enabled": false,
      "level": "预警",
      "displayName": "逐点形态偏离",
      "type": "morphology",
      "provenance": "domain-expert",
      "provenanceNote": "与参考曲线逐点对齐后计算残差面积比。捕获整体形态异常但各段统计量均未超阈值的灰色曲线。",
      "parameters": {
        "areaDiffRatioThreshold": 0.25,
        "maxAbsDevRatio": 1.0
      },
      "status": "pending_implementation"
    }
  },

